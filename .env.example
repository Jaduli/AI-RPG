API_URL=https://your-api-url
API_KEY=your_api_key_here

# Default models used in story continuation (main) & memory/summary creation (mem).
# Can be left empty or overridden in front.
API_MAIN_MODEL=model_name
API_MEM_MODEL=model_name

# Game mode determines app layout & default prompt for storytelling.
# Default is rpg. Keep line below if you prefer storyteller (no RPG elements).
# Can be overridden in front.
GAMEMODE=storyteller

# 'Hybrid' changes story generation prompt for a mix of RPG elements and AI-controlled 
# storytelling (less player agency than rpg, more reactive than storyteller).
HYBRID=0